+            # STARTTLS. use_tls drives whether we attempt the upgrade.
+            with smtplib.SMTP(config.smtp_host, port,
+                              timeout=SMTP_TIMEOUT_SECONDS) as server:
+                server.ehlo()
+                if config.use_tls:
+                    server.starttls(context=context)
+                    server.ehlo()
+                if config.smtp_username:
