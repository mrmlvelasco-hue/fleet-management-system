FLASK_ENV=development
SECRET_KEY=change-me-in-production

# MySQL connection (used automatically when DB_NAME is set and DATABASE_URL is not)
DB_USER=root
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=Fleet

# Alternative: set DATABASE_URL directly to override the above (e.g. sqlite:///fms_dev.db)
# DATABASE_URL=sqlite:///fms_dev.db

REDIS_URL=redis://localhost:6379/0
SESSION_TIMEOUT_MINUTES=30
MAX_FAILED_LOGIN_ATTEMPTS=5
